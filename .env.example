# Copy to apps/web/.env.local for local Next.js development (never commit real secrets).

# --- Supabase (public client; safe to expose in browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: use only in API routes / server code. Never expose to the client.
# If unset, supabaseAdmin falls back to anon (not recommended for production).
SUPABASE_SERVICE_ROLE_KEY=

# --- Inbound rate limiting (apps/web/middleware.ts) ---
# Max requests per IP per window for paths under /api and /blog.
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_MS=60000
