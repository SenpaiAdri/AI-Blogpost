# Copy to backend/.env and fill in real values (never commit .env).
# Used by the Python ingestion pipeline (e.g. python backend/src/main.py).

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
# Prefer SUPABASE_SERVICE_KEY; SUPABASE_SERVICE_ROLE_KEY is also accepted.
SUPABASE_SERVICE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers (optional; mock fallback if both missing) ---
GOOGLE_API_KEY=
OPEN_ROUTER_API_KEY=

# --- SSRF protection (validate_url in security.py) ---
# Comma-separated hostnames allowed for fetched article URLs. Empty = allow any
# non-private host (still blocks localhost, credentials in URL, etc.).
# Example for typical news/RSS sources:
# URL_ALLOWLIST_DOMAINS=theverge.com,techcrunch.com,wired.com,openai.com,technologyreview.com,news.ycombinator.com,blog.google,deepmind.google,anthropic.com

URL_ALLOWLIST_DOMAINS=

# --- Outbound rate limits (ingest RSS + scraper) ---
# Default max requests per second per remote host.
RATE_LIMIT_RPS_DEFAULT=2.0
# Optional per-domain overrides: domain dots/hyphens become underscores, uppercased.
# Examples (match urlparse netloc, e.g. r.jina.ai, www.theverge.com):
# RATE_LIMIT_RPS_R_JINA_AI=1.0
# RATE_LIMIT_RPS_WWW_THEVERGE_COM=1.5
