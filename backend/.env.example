# Copy to backend/.env and fill in real values (never commit .env).
# Used by the Python ingestion pipeline (e.g. python backend/src/main.py).

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
# Prefer SUPABASE_SERVICE_KEY; SUPABASE_SERVICE_ROLE_KEY is also accepted.
SUPABASE_SERVICE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers (required for publishing; no mock posts) ---
GOOGLE_API_KEY=
OPEN_ROUTER_API_KEY=

# --- SSRF protection (validate_url in security.py) ---
# Comma-separated hostnames allowed for fetched article URLs. Empty = allow any
# non-private host (still blocks localhost, credentials in URL, etc.).
# Suggested allowlist aligned with rss_feeds.py + common article hosts (one line):
# URL_ALLOWLIST_DOMAINS=theverge.com,techcrunch.com,arstechnica.com,wired.com,engadget.com,cnet.com,zdnet.com,bbc.co.uk,bbci.co.uk,theregister.com,bleepingcomputer.com,krebsonsecurity.com,github.blog,amazon.com,openai.com,technologyreview.com,hnrss.org,blog.google,deepmind.google,huggingface.co,ycombinator.com,substack.com,medium.com,reuters.com,bloomberg.com,wsj.com,ft.com,nytimes.com,washingtonpost.com,axios.com,protocol.com,404media.co,semianalysis.com

URL_ALLOWLIST_DOMAINS=

# --- Outbound rate limits (ingest RSS + scraper) ---
# Default max requests per second per remote host.
RATE_LIMIT_RPS_DEFAULT=2.0
# Optional per-domain overrides: domain dots/hyphens become underscores, uppercased.
# Examples (match urlparse netloc, e.g. r.jina.ai, www.theverge.com):
# RATE_LIMIT_RPS_R_JINA_AI=1.0
# RATE_LIMIT_RPS_WWW_THEVERGE_COM=1.5
